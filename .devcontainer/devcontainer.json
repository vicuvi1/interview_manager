{
  "name": "interview-manager",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "bash .devcontainer/setup-env.sh && npm install",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Interview Manager",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
