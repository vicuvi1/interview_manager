# Copy to .env.local and fill in from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Admin access code (server-only, do NOT prefix with NEXT_PUBLIC) ---
# The code a user types to unlock the Admin role on the login page.
ADMIN_ACCESS_CODE=INTERVIEW-PRO-2025
# Supabase service_role key (Project Settings -> API -> service_role secret).
# Required so the server can grant the admin role after verifying the code.
# HIGH SECRET — never expose to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
