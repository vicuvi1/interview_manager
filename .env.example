# Copy to .env.local and fill in from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# --- Admin access code (server-only, do NOT prefix with NEXT_PUBLIC) ---
# The code a user types to unlock the Admin role on the login page.
ADMIN_ACCESS_CODE=INTERVIEW-PRO-2025
# Supabase service_role key (Project Settings -> API -> service_role secret).
# Required so the server can grant the admin role after verifying the code,
# AND for the Google Calendar sync (webhook/cron drain use it). Fill this in!
# HIGH SECRET — never expose to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Calendar sync (server-only, do NOT prefix with NEXT_PUBLIC) ---
# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client (Web).
# See docs/GOOGLE_CALENDAR_SETUP.md for the click-by-click guide.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must EXACTLY match an Authorized redirect URI in the Google console, e.g.
# https://your-app.vercel.app/api/google/oauth/callback  (leave blank in local dev).
GOOGLE_OAUTH_REDIRECT_URI=
# Any long random string. Gates the internal sync endpoint; the app copies it
# into the DB config so pg_cron/pg_net can authenticate. Keep it secret.
CRON_SECRET=change-me-to-a-long-random-string
