# Copy this file to `.env` and adjust the values.

# Display name for the API
APP_NAME=Interview Manager

# Secret key the single admin ("caller") uses to authenticate.
# Send it in the `X-Admin-Key` header. CHANGE THIS before any real use.
ADMIN_API_KEY=change-me-admin-key

# SQLAlchemy database URL. Default is a local SQLite file.
DATABASE_URL=sqlite:///./interview_manager.db

# Fallback IANA timezone used when a candidate has not supplied one.
DEFAULT_TIMEZONE=UTC
